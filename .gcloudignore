# This file specifies files that are *not* uploaded to Google Cloud Platform
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).

#!include:.gitignore

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development files
.env
.env.development
.env.local
.env.test

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Test files
test/
tests/
__tests__/
*.test.js
*.spec.js

# Documentation
README.md
docs/
*.md

# Git
.git/
.gitignore

# Frontend build artifacts (if any)
frontend/dist/
frontend/build/
frontend/node_modules/

# Client applications (not needed on server)
Client/
StealthClient/

# Development tools
nodemon.json
.eslintrc*
.prettierrc*

# Temporary files
tmp/
temp/
*.tmp

# Coverage reports
coverage/
.nyc_output/